# ============================================================================
#  Gofile Waifu Bot — environment configuration
# ============================================================================
#  Copy this file to .env  →  fill in your values  →  run `python bot.py`
#  For Railway, set these as service variables in the Railway dashboard
#  (Settings → Variables) instead of using a .env file.
# ============================================================================

# Telegram bot token from @BotFather (REQUIRED)
BOT_TOKEN=8559957423:AAFwQISnYeQ7TwOCxs6Ibo52Og9MlMLbDik

# ---------------------------------------------------------------------------
# REQUIRED for files larger than 20 MB (supports up to 2 GB, or 4 GB if sender
# is a Telegram Premium user). Get these from https://my.telegram.org/apps
#   (sign in with your phone → "API development tools" → create app → copy
#    api_id and api_hash). These are per-developer, not per-bot.
# ---------------------------------------------------------------------------
API_ID=39027759
API_HASH=ea20df34f5f44c21c493eff664559ba3

# Optional: your Telegram user ID for error alerts (get from @userinfobot)
DEV_CHAT_ID=8456043064

# Optional: Gofile account token for permanent storage
# Leave empty for guest uploads (10-day retention)
# Get from https://gofile.io/myprofile
GOFILE_TOKEN=

# ---------------------------------------------------------------------------
# Mini App (REQUIRED for files > 2 GB / 4 GB — supports up to 15 GB+)
# ---------------------------------------------------------------------------
# Public HTTPS URL where the Mini App is reachable from the internet.
#
# RAILWAY USERS: leave this empty — Railway auto-provides RAILWAY_PUBLIC_DOMAIN
# on first deploy, and the bot auto-configures MINIAPP_URL from it. Just make
# sure to enable "Public Networking" on your Railway service so the domain
# is generated.
#
# LOCAL / SELF-HOSTED USERS: use ONE of:
#   1. Cloudflare Tunnel (recommended, free, no signup):
#        cloudflared tunnel --url http://localhost:8080
#        -> Copy the resulting https://xxx.trycloudflare.com URL
#        -> Set MINIAPP_URL=https://xxx.trycloudflare.com/miniapp
#
#   2. ngrok (free with signup):
#        ngrok http 8080
#        -> Set MINIAPP_URL=https://abcd-1-2-3-4.ngrok-free.app/miniapp
#
#   3. Your own reverse proxy (nginx/Caddy) with a domain + TLS cert
#
# Leave empty to disable big-file uploads (files up to 2 GB still work
# via Telethon; 4 GB from Premium senders also works).
MINIAPP_URL=

# ---------------------------------------------------------------------------
# HTTP server config
# ---------------------------------------------------------------------------
# Local HTTP port the bot listens on.
# RAILWAY USERS: don't set this — Railway auto-injects PORT at runtime and
# the bot reads it automatically. Setting PORT yourself will break things.
# LOCAL USERS: defaults to 8080. Change only if 8080 is taken.
WEB_PORT=8080

# ---------------------------------------------------------------------------
# Performance tuning (optional)
# ---------------------------------------------------------------------------
# Number of parallel MTProto connections to use when downloading large files
# from Telegram (via the Telethon bridge). Each worker opens its own stream
# and writes to a different byte range of the file → ~5-10x speedup vs single.
#
# Recommended values:
#   8   — Default. Sweet spot on Railway / typical VPS (5-15 MB/s for big files)
#   4   — Low-RAM (512MB) or slow disk
#   12  — Fast server with 2GB+ RAM and fat pipe (15-30 MB/s)
#   16  — Max. Diminishing returns past this.
TELETHON_PARALLEL_CHUNKS=16

# ---------------------------------------------------------------------------
# Railway-only: persistent storage (OPTIONAL but recommended)
# ---------------------------------------------------------------------------
# Path to the persistent data directory. Railway auto-mounts volumes at /data
# when you create one in the dashboard; if /data exists, the bot uses it
# automatically. Override only if you mounted the volume elsewhere.
# Leave empty for auto-detection.
DATA_DIR=

# ============================================================================
#  Quick-start checklist (Railway one-click deploy):
# ============================================================================
#   1. Click "Deploy on Railway" button in README
#   2. In Railway service → Variables, set:
#        BOT_TOKEN   = <from @BotFather>
#        API_ID      = <from my.telegram.org/apps>
#        API_HASH    = <from my.telegram.org/apps>
#   3. In Railway service → Settings → Networking:
#        Toggle "Public Networking" ON
#        -> Railway generates a public domain (e.g. mybot.up.railway.app)
#        -> Bot auto-picks this up via RAILWAY_PUBLIC_DOMAIN env var
#   4. (Optional) Settings → Volumes → Add Volume:
#        Mount path: /data
#        -> Persists Telethon session across restarts (avoids re-login alerts)
#   5. Deploy → wait ~30s → check /health endpoint → open your bot in Telegram
# ============================================================================
